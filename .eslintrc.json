{
    "env": {
        "browser": true
    },
	"root": true,

	"plugins": ["@typescript-eslint"],
    "extends": [
        "standard",
        "eslint:recommended",
		"plugin:@typescript-eslint/eslint-recommended",
		"plugin:@typescript-eslint/recommended"
    ],
    "parserOptions": {
        "ecmaVersion": 12,
        "sourceType": "module"
    },
    "rules": {
        "semi": [2, "always"],
        "no-throw-literal": 0,
        "indent": ["error", "tab"],
        "no-tabs": 0,
        "@typescript-eslint/no-unused-vars": [
            "error",
            { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }
        ]
    },

    "overrides": [
        {
			"files": ["folium_zoom_state/walk.js"],
			"rules": {
                "semi": [2, "always"],
                "no-throw-literal": 0,
                "indent": ["error", "tab"],
                "no-tabs": 0,
                "no-undef": 0
            }
		},
        {
			"files": ["**/*.ts"],
            "parser": "@typescript-eslint/parser",
            "parserOptions": {
                "ecmaVersion": 12,
                "sourceType": "module",
                "project": ["./tsconfig.json"]
            }

		}
	]
}
